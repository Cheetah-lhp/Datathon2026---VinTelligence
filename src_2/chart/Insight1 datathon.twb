      <aliases enabled='yes' />
      <column caption='AOV' datatype='real' name='[Calculation_4067021646491648]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_spending])/SUM([total_orders])' />
      </column>
      <column caption='First Purchase Date' datatype='date' name='[Calculation_4067021650767874]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [customer_id] : MIN([order_date]) }' />
      </column>
      <column caption='Months Since Signup' datatype='integer' name='[Calculation_4067021650972675]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;month&apos;, [Calculation_4067021650767874], [order_date])' />
